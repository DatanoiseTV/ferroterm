{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ferroterm",
  "version": "0.1.0",
  "identifier": "com.datanoise.ferroterm",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1000,
        "height": 660,
        "minWidth": 480,
        "minHeight": 320,
        "titleBarStyle": "Overlay",
        "backgroundColor": "#14151f"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'wasm-unsafe-eval'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"]
  }
}
